<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UIBank Admin</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: #f4f6fa;
        }

        .navbar {
            background: linear-gradient(90deg, #0f2027, #203a43, #2c5364);
            padding: 14px 0;
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 22px;
            color: white !important;
            letter-spacing: 0.5px;
        }

        .nav-link {
            font-weight: 500;
            color: #e8e8e8 !important;
            margin: 0 8px;
            position: relative;
        }

            .nav-link:hover {
                color: white !important;
            }

            .nav-link::after {
                content: '';
                width: 0;
                height: 2.5px;
                background: #00d4ff;
                position: absolute;
                left: 0;
                bottom: -4px;
                transition: 0.3s;
                border-radius: 2px;
            }

            .nav-link:hover::after {
                width: 100%;
            }

        .auth-btn {
            border: 2px solid white;
            color: white;
            padding: 6px 14px;
            border-radius: 8px;
            font-weight: 600;
            transition: 0.3s;
        }

            .auth-btn:hover {
                background: white;
                color: #203a43;
            }

        footer {
            background: #0f2027;
            color: #bdbdbd;
            padding: 18px 0;
            text-align: center;
            margin-top: 35px;
        }

            footer a {
                color: #00d4ff;
                text-decoration: none;
                font-weight: 500;
            }

                footer a:hover {
                    text-decoration: underline;
                }
    </style>
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container-fluid px-4">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">UIBank Admin</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse justify-content-between" id="navMenu">
                    <ul class="navbar-nav">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacy</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer>
        <div class="container">
            &copy; 2026 - UIBank Admin Panel | Designed for Placement & Real World
            <br />
            <a asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
