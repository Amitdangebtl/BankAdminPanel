@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="dashboard-wrapper">
    <div class="header">
        <h2>Banking Admin Panel</h2>
        <p>Manage customers, accounts & transactions efficiently</p>
    </div>

    <div class="container mt-4">

        <!-- Customers Section -->
        <div class="card section-card mb-4">
            <h4><i class="bi bi-people-fill"></i> Customers</h4>
            <div class="row g-3">
                <div class="col-md-3"><a href="/BankAdmin/CustomerListView" class="btn btn-panel"><i class="bi bi-list"></i> Customer List</a></div>
                <div class="col-md-3"><a href="/BankAdmin/CreateCustomerView" class="btn btn-panel success"><i class="bi bi-person-plus"></i> Create Customer</a></div>
                <div class="col-md-3"><a href="/BankAdmin/UpdateCustomerView" class="btn btn-panel warning"><i class="bi bi-pencil-square"></i> Update Customer</a></div>
                <div class="col-md-3"><a href="/BankAdmin/DeleteCustomerView" class="btn btn-panel danger"><i class="bi bi-trash"></i> Delete Customer</a></div>
            </div>
        </div>

        <!-- Accounts Section -->
        <div class="card section-card mb-4">
            <h4><i class="bi bi-bank2"></i> Accounts</h4>
            <div class="row g-3">
                <div class="col-md-3"><a href="/BankAdmin/AccountListView" class="btn btn-panel"><i class="bi bi-wallet2"></i> Account List</a></div>
                <div class="col-md-3"><a href="/BankAdmin/CreateAccountView" class="btn btn-panel success"><i class="bi bi-plus-circle"></i> Create Account</a></div>
                <div class="col-md-3"><a href="/BankAdmin/UpdateAccountView" class="btn btn-panel warning"><i class="bi bi-arrow-repeat"></i> Update Account</a></div>
                <div class="col-md-3"><a href="/BankAdmin/DeleteAccountView" class="btn btn-panel danger"><i class="bi bi-x-circle"></i> Delete Account</a></div>
            </div>
        </div>

        <!-- Quick Actions Section -->
        <div class="card section-card quick-actions mt-3">
            <h4><i class="bi bi-lightning-charge-fill"></i> Quick Actions</h4>
            <div class="row g-3">
                <div class="col-md-4"><a href="/BankAdmin/DepositView" class="btn btn-panel success"><i class="bi bi-cash-stack"></i> Deposit Money</a></div>
                <div class="col-md-4"><a href="/BankAdmin/WithdrawView" class="btn btn-panel danger"><i class="bi bi-cash-coin"></i> Withdraw Money</a></div>
                <div class="col-md-4"><a href="/BankAdmin/TransectionHistoryView" class="btn btn-panel info"><i class="bi bi-clock-history"></i> Transaction History</a></div>

                <!-- 🔥 Transfer Money Button Added -->
                <div class="col-md-4"><a href="/BankAdmin/TransferView" class="btn btn-panel dark"><i class="bi bi-arrow-left-right"></i> Transfer Money</a></div>
            </div>
        </div>

    </div>
</div>

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" />

<style>
    .dashboard-wrapper {
        background: #f5f7fa;
        min-height: 100vh;
    }

    .header {
        background: linear-gradient(135deg,#1e3c72,#2a5298);
        color: white;
        text-align: center;
        padding: 25px 10px;
        border-radius: 0 0 20px 20px;
        box-shadow: 0px 4px 15px rgba(0,0,0,0.2);
        margin-bottom: 20px;
    }

    .section-card {
        padding: 20px;
        border-radius: 15px;
        box-shadow: 0px 3px 12px rgba(0,0,0,0.1);
        border: none;
    }

        .section-card h4 {
            font-weight: 700;
            margin-bottom: 15px;
            font-size: 20px;
            color: #1e3c72;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

    .btn-panel {
        background: white;
        color: #1e3c72;
        border: 2px solid #1e3c72;
        font-size: 16px;
        padding: 12px;
        border-radius: 12px;
        font-weight: 600;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        transition: 0.3s;
    }

        .btn-panel:hover {
            background: #1e3c72;
            color: white;
            transform: translateY(-3px);
            box-shadow: 0px 5px 15px rgba(30,60,114,0.3);
        }

        .btn-panel.success {
            border-color: #198754;
            color: #198754;
        }

            .btn-panel.success:hover {
                background: #198754;
                color: white;
            }

        .btn-panel.warning {
            border-color: #ffc107;
            color: #d39e00;
        }

            .btn-panel.warning:hover {
                background: #ffc107;
                color: black;
            }

        .btn-panel.danger {
            border-color: #dc3545;
            color: #dc3545;
        }

            .btn-panel.danger:hover {
                background: #dc3545;
                color: white;
            }

        .btn-panel.info {
            border-color: #0dcaf0;
            color: #0a95b0;
        }

            .btn-panel.info:hover {
                background: #0dcaf0;
                color: black;
            }

        .btn-panel.dark {
            border-color: #212529;
            color: #212529;
        }

            .btn-panel.dark:hover {
                background: #212529;
                color: white;
            }
</style>
