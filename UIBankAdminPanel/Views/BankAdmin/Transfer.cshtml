@{
    ViewData["Title"] = "Transfer Money";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5 d-flex justify-content-center" style="min-height:80vh;">
    <div style="width:100%; max-width:450px;">

        <div class="mb-3">
            <a href="/BankAdmin/AdminDashboard" class="btn shadow-sm"
               style="background:#0A1F44; color:white; padding:6px 14px; border-radius:6px; font-weight:600;">
                ← Back to Dashboard
            </a>
        </div>

        <div class="card p-4 shadow-lg border-0 rounded-4" style="background:#fff;">
            <div class="text-center py-2 mb-4"
                 style="background:linear-gradient(90deg,#0A1F44,#112D6B); color:white; font-size:20px; font-weight:700; border-radius:12px;">
                Transfer Money
            </div>

            <div id="previewBox" class="alert text-dark text-start mb-3"
                 style="display:none; white-space:pre-line; background:#F0F6FF; border:1px solid #112D6B; border-radius:10px; font-size:13px;"></div>

            <form id="transferForm" novalidate>
                <div class="mb-3">
                    <label class="form-label fw-semibold">From Account</label>
                    <input id="fromAcc" placeholder="Enter Account Number" type="number"
                           required class="form-control input-box p-2 mb-1" oninput="loadPreview(this.value)" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">To Account</label>
                    <input id="toAcc" placeholder="Enter Account Number" type="number"
                           required class="form-control input-box p-2 mb-1" />
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Amount</label>
                    <input id="amount" placeholder="Enter Amount" type="number"
                           required class="form-control input-box p-2" oninput="validateTransfer()" />
                </div>

                <button id="transferBtn" type="button" class="btn w-100" disabled onclick="confirmTransfer()"
                        style="background:linear-gradient(90deg,#198754,#28a745); color:white; font-weight:700; padding:12px; border-radius:8px; font-size:16px;">
                    Transfer
                </button>
            </form>
        </div>
    </div>
</div>

<script>
    async function loadPreview(accNo) {
        const box = document.getElementById("previewBox");
        if (!accNo || accNo <= 0) {
            box.style.display = "none";
            return;
        }

        try {
            let r = await fetch("/BankAdmin/AccountListAPI");
            let accounts = await r.json();

            let acc = null;
            for (let i = 0; i < accounts.length; i++) {
                if (accounts[i].accountNumber == accNo) {
                    acc = accounts[i];
                    break;
                }
            }

            if (!acc) {
                box.style.display = "block";
                box.innerText = "❌ Account not found!";
                return;
            }

            let r2 = await fetch("/BankAdmin/CustomerListAPI");
            let customers = await r2.json();

            let cust = null;
            for (let j = 0; j < customers.length; j++) {
                if (customers[j].customerId == acc.customerId) {
                    cust = customers[j];
                    break;
                }
            }

            box.style.display = "block";
            box.innerText =
                "Account No: " + acc.accountNumber +
                "\nBalance: ₹ " + acc.balance +
                "\nType: " + acc.accountType +
                "\n\nCustomer: " + (cust?.name || "") +
                "\nPhone: " + (cust?.phone || "") +
                "\nEmail: " + (cust?.email || "") +
                "\nAddress: " + (cust?.address || "");

            validateTransfer();
        } catch(err) {
            console.log("Preview error →", err);
        }
    }

    function validateTransfer() {
        let f = document.getElementById("fromAcc").value;
        let t = document.getElementById("toAcc").value;
        let a = document.getElementById("amount").value;
        let previewErr = document.getElementById("previewBox").innerText.includes("❌");

        let valid = !(f === "" || t === "" || a === "" || a <= 0 || previewErr);
        document.getElementById("transferBtn").disabled = !valid;
    }

    async function callTransferAPI() {
        try {
            let fromAcc = document.getElementById("fromAcc").value;
            let toAcc = document.getElementById("toAcc").value;
            let amt = document.getElementById("amount").value;

            let r = await fetch("/BankAdmin/TransferAPI?fromAccNo=" + fromAcc + "&toAccNo=" + toAcc + "&amount=" + amt,
                                { method: "POST" });

            let msg = await r.text();
            alert(msg);

            // 🔥 Transfer ke baad page auto reload
            if (msg.includes("successful")) {
                window.location.reload();
            }

        } catch(err) {
            console.log("Transfer error →", err);
            alert("❌ API error while transferring");
        }
    }

    function confirmTransfer() {
        let c = confirm("Confirm Transfer?\nPress OK to Transfer or Cancel to Stop.");
        if (c) {
            callTransferAPI();
        }
    }
</script>

<style>
    .input-box {
        border: 2px solid #dce1eb;
        border-radius: 10px;
        font-size: 15px;
        padding: 10px;
    }

        .input-box:focus {
            border-color: #112D6B;
            box-shadow: 0 0 5px rgba(17,45,107,0.25);
        }
</style>
