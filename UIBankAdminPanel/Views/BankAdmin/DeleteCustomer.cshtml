@{
    ViewData["Title"] = "Delete Customer";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5 d-flex justify-content-center">
    <div style="width:100%; max-width:420px;">

        <!-- Back Button -->
        <div class="mb-3">
            <a href="/BankAdmin/AdminDashboard" class="btn shadow-sm"
               style="background:#0A1F44; color:white; padding:7px 16px; border-radius:8px; font-weight:600;">
                ← Back to Dashboard
            </a>
        </div>

        <h2 class="text-center fw-bold mb-4" style="color:#112D6B;">Delete Customer</h2>

        <div class="card p-4 shadow-lg border-0 rounded-4" style="background:rgba(17,45,107,0.04);">

            <!-- Customer Preview Box -->
            <div id="previewBox" class="alert text-center text-dark mb-3"
                 style="display:none; border:1px solid #112D6B; background:#F0F5FF; white-space:pre-line;">
                <b>Customer Details</b><br>
                <span id="prevData"></span>
            </div>

            <!-- Account exist warning alert -->
            <div id="deleteAlert" class="alert alert-warning text-center mb-3" style="display:none;"></div>

            <!-- Delete Form -->
            <form id="updateForm" method="post" action="/BankAdmin/DeleteCustomer" onsubmit="return confirmDelete(event)">

                <input id="custId" name="customerId" placeholder="Enter Customer ID"
                       type="number" required class="form-control mb-3 rounded-3 p-2"
                       oninput="loadCustomer(this.value)" />

                <button type="submit" class="btn w-100 shadow-sm"
                        style="background:linear-gradient(90deg,#0A1F44,#112D6B); color:white; padding:10px;
                               border-radius:10px; font-size:16px; font-weight:700;">
                    Delete Customer
                </button>

                @if (ViewBag.Msg != null)
                {
                    <div class="alert alert-danger text-center mt-3">@ViewBag.Msg</div>
                }

            </form>
        </div>
    </div>
</div>

<style>
    .form-control:focus {
        box-shadow: 0 0 6px rgba(17,45,107,0.3);
        border-color: #112D6B;
    }
</style>

<script>
    async function loadCustomer(id) {
        if (!id) {
            document.getElementById("previewBox").style.display = "none";
            document.getElementById("deleteAlert").style.display = "none";
            return;
        }
        try {
            // Customer list fetch
            let r = await fetch("/BankAdmin/CustomerListAPI");
            let d = await r.json();

            for (let i = 0; i < d.length; i++) {
                if (d[i].customerId == id) {
                    // show preview
                    document.getElementById("previewBox").style.display = "block";
                    document.getElementById("prevData").innerText =
                        "ID: " + d[i].customerId + "\nName: " + d[i].name +
                        "\nPhone: " + d[i].phone + "\nAddress: " + d[i].address +
                        "\nEmail: " + d[i].email;

                    // Account check
                    let acc = await fetch("/BankAdmin/AccountListAPI");
                    let accData = await acc.json();

                    for (let j = 0; j < accData.length; j++) {
                        if (accData[j].customerId == id) {
                            document.getElementById("deleteAlert").style.display = "block";
                            document.getElementById("deleteAlert").innerText =
                                "⚠ This customer has an active account!\nPlease delete the account first before deleting the customer.";
                            return false;
                        }
                    }

                    document.getElementById("deleteAlert").style.display = "none";
                    return true;
                }
            }

            // not found case
            document.getElementById("previewBox").style.display = "block";
            document.getElementById("prevData").innerText = "No customer found!";
        } catch (err) {
            console.log("Load error →", err);
        }
    }

    function confirmDelete(event) {
        event.preventDefault();

        // if account exists block delete
        if (document.getElementById("deleteAlert").style.display === "block") {
            alert("❌ Customer ka account exist karta hai!\nPehle account delete kare.");
            return false;
        }

        // confirmation box
        let c = confirm("Are you sure you want to delete this customer?\n\nPress OK to Delete or Cancel to Stop.");
        if (c) {
            document.getElementById("updateForm").submit();
        }
        return false;
    }
</script>
