@{
    ViewData["Title"] = "Withdraw Money";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5 d-flex justify-content-center align-items-center" style="min-height:80vh;">
    <div style="width:100%; max-width:420px;">

        <!-- Back Button -->
        <div class="mb-3">
            <a href="/BankAdmin/AdminDashboard" class="btn shadow-sm"
               style="background:#0A1F44; color:white; padding:7px 16px; border-radius:8px; font-weight:600;">
                ← Back to Dashboard
            </a>
        </div>

        <div class="card p-4 shadow-lg border-0 rounded-4" style="background:rgba(17,45,107,0.04);">

            <!-- Header -->
            <div class="text-center py-2 mb-4"
                 style="background:linear-gradient(90deg,#0A1F44,#112D6B); color:white; font-size:20px; font-weight:700; border-radius:12px;">
                Withdraw Money
            </div>

            <!-- Preview Box -->
            <div id="previewBox" class="alert text-dark text-start mb-3"
                 style="display:none; white-space:pre-line; background:#F0F6FF; border:1px solid #112D6B; border-radius:10px; font-size:13px;"></div>

            <!-- Warning if balance insufficient -->
            <div id="warnBox" class="alert alert-danger text-center" style="display:none; font-size:14px;"></div>

            <!-- Form -->
            <form id="wdForm" method="post" action="/BankAdmin/Withdraw"
                  onsubmit="return confirmWithdraw(event)" oninput="validateForm()" novalidate>

                <label class="form-label fw-semibold">Account Number</label>
                <input id="accNo" name="accNo" placeholder="Enter Account Number" type="number"
                       required class="form-control input-box p-2 mb-3" oninput="loadPreview(this.value)" />

                <label class="form-label fw-semibold">Amount</label>
                <input id="amount" name="amount" placeholder="Enter Amount" type="number"
                       required class="form-control input-box p-2 mb-4" />

                <button id="submitBtn" type="submit" class="btn w-100 withdraw-btn" disabled>Withdraw</button>

                @if (ViewBag.Msg != null)
                {
                    <div class="alert alert-warning text-center mt-3">@ViewBag.Msg</div>
                }
            </form>
        </div>
    </div>
</div>

<script>
    async function loadPreview(accNo) {
        const previewBox = document.getElementById("previewBox");
        const warnBox = document.getElementById("warnBox");

        if (!accNo || accNo <= 0) {
            previewBox.style.display = "none";
            warnBox.style.display = "none";
            return;
        }

        try {
            let r1 = await fetch("/BankAdmin/AccountListAPI");
            let r2 = await fetch("/BankAdmin/CustomerListAPI");

            let accounts = await r1.json();
            let customers = await r2.json();

            let acc = null;
            let cust = null;

            // Find account
            for (let i = 0; i < accounts.length; i++) {
                if (accounts[i].accountNumber == accNo) {
                    acc = accounts[i];
                    break;
                }
            }

            if (!acc) {
                previewBox.style.display = "block";
                previewBox.innerText = "❌ Account not found!";
                document.getElementById("submitBtn").disabled = true;
                return false;
            }

            // Find linked customer
            for (let j = 0; j < customers.length; j++) {
                if (customers[j].customerId == acc.customerId) {
                    cust = customers[j];
                    break;
                }
            }

            // Show preview
            previewBox.style.display = "block";
            previewBox.innerText =
                "Account No: " + acc.accountNumber +
                "\nBalance: ₹ " + acc.balance +
                "\nType: " + acc.accountType +
                "\n\nCustomer: " + (cust?.name || "") +
                "\nPhone: " + (cust?.phone || "") +
                "\nEmail: " + (cust?.email || "") +
                "\nAddress: " + (cust?.address || "");

            // If balance < withdrawal amount → warn + block
            if (document.getElementById("amount").value && acc.balance < document.getElementById("amount").value) {
                warnBox.style.display = "block";
                warnBox.innerText = "⚠ Insufficient Balance! Please enter lower amount.";
                document.getElementById("submitBtn").disabled = true;
                return false;
            } else {
                warnBox.style.display = "none";
            }

            validateForm();
            return true;

        } catch (err) {
            console.log("Preview load error →", err);
        }
    }

    function validateForm() {
        let accNo = document.getElementById("accNo").value;
        let amt = document.getElementById("amount").value;
        let preview = document.getElementById("previewBox").innerText;
        let warn = document.getElementById("warnBox").style.display === "block";

        let valid = !(accNo === "" || accNo <= 0 || amt === "" || amt <= 0 || warn || preview.includes("❌"));

        document.getElementById("submitBtn").disabled = !valid;
    }

    function confirmWithdraw(event) {
        event.preventDefault();

        if (document.getElementById("submitBtn").disabled) {
            alert("❌ Invalid withdrawal request!");
            return false;
        }

        let c = confirm("Confirm Withdrawal?\nPress OK to Withdraw or Cancel to Stop.");
        if (c) {
            document.getElementById("wdForm").submit();
        }
        return false;
    }
</script>

<style>
    .input-box {
        border: 2px solid #dce1eb;
        border-radius: 10px;
        font-size: 15px;
    }

    .withdraw-btn {
        background: linear-gradient(90deg,#dc3545,#8B0000);
        color: white;
        font-weight: 600;
        border-radius: 10px;
        padding: 12px;
        font-size: 16px;
    }

        .withdraw-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(220,53,69,0.3);
        }

    .card {
        background: white;
    }
</style>
