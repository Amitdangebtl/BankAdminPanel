@{
    ViewData["Title"] = "Transaction History";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5 d-flex justify-content-center" style="min-height:80vh;">
    <div style="width:100%; max-width:600px;">

        <!-- Back Button -->
        <div class="mb-3">
            <a href="/BankAdmin/AdminDashboard" class="btn shadow-sm"
               style="background:#0A1F44; color:white; padding:6px 14px; border-radius:6px; font-weight:600;">
                ← Back to Dashboard
            </a>
        </div>

        <h2 class="text-center fw-bold mb-4" style="color:#112D6B;">Transaction History</h2>

        <!-- Account Preview Box -->
        <div id="previewBox" class="alert text-dark text-start mb-3"
             style="display:none; white-space:pre-line; background:#F0F6FF; border:1px solid #112D6B; border-radius:10px; font-size:13px;"></div>

        <input id="accNo" placeholder="Enter Account Number" type="number"
               class="form-control input-box mb-2" oninput="loadPreview(this.value)" />

        <button onclick="loadTx()" class="btn w-100 mb-3"
                style="background:linear-gradient(90deg,#0A1F44,#112D6B); color:white; padding:10px; border-radius:8px; font-weight:700;">
            Load Transactions
        </button>

        <div class="card p-3 shadow-lg border-0 rounded-4">
            <div class="table-responsive">
                <table id="txTable" class="table table-bordered text-center align-middle">
                    <thead>
                        <tr><th colspan="4" class="text-muted">Enter Account Number...</th></tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>

    </div>
</div>

<script>
    async function loadPreview(accNo) {
        const box = document.getElementById("previewBox");
        if (!accNo || accNo <= 0) {
            box.style.display = "none";
            return;
        }

        try {
            let r1 = await fetch("/BankAdmin/AccountListAPI");
            let r2 = await fetch("/BankAdmin/CustomerListAPI");

            let accounts = await r1.json();
            let customers = await r2.json();

            let acc = null;
            let cust = null;

            // Find account
            for (let i = 0; i < accounts.length; i++) {
                if (accounts[i].accountNumber == accNo) {
                    acc = accounts[i];
                    break;
                }
            }

            if (!acc) {
                box.style.display = "block";
                box.innerText = "❌ Account not found!";
                return;
            }

            // Find customer
            for (let j = 0; j < customers.length; j++) {
                if (customers[j].customerId == acc.customerId) {
                    cust = customers[j];
                    break;
                }
            }

            box.style.display = "block";
            box.innerText =
                "Account No: " + acc.accountNumber +
                "\nBalance: ₹ " + acc.balance +
                "\nType: " + acc.accountType +
                "\n\nCustomer: " + (cust?.name || "") +
                "\nPhone: " + (cust?.phone || "") +
                "\nEmail: " + (cust?.email || "") +
                "\nAddress: " + (cust?.address || "");

        } catch(err) {
            console.log("Preview error →", err);
        }
    }

    async function loadTx() {
        const table = document.getElementById("txTable").querySelector("tbody");
        try {
            let accNo = document.getElementById("accNo").value;
            let r = await fetch("/BankAdmin/TransectionHistory?accNo=" + accNo);
            let d = await r.json();

            if(!Array.isArray(d) || d.length === 0) {
                table.innerHTML = "<tr><td colspan='4'>No Transactions Found</td></tr>";
                return;
            }

            let html = "<tr><th>Transaction Type</th><th>Amount</th><th>Date</th><th>Status</th></tr>";

            for(let i = 0; i < d.length && i < 10; i++) {
                html += `<tr>
                            <td>${d[i].type}</td>
                            <td>₹ ${d[i].amount}</td>
                            <td>${d[i].date ? d[i].date : "-"}</td>
                            <td class="text-success fw-bold">Success</td>
                         </tr>`;
            }

            table.innerHTML = html;
        }
        catch(e) {
            console.log("Transaction error →", e);
            alert("❌ API not running or URL wrong");
        }
    }
</script>

<style>
    .input-box {
        border: 2px solid #dce1eb;
        border-radius: 10px;
        font-size: 15px;
        padding: 10px;
    }

        .input-box:focus {
            border-color: #112D6B;
            box-shadow: 0 0 5px rgba(17,45,107,0.25);
        }
</style>
